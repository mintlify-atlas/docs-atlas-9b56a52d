  "keyFeatures": [
    "User authentication with NextAuth.js (Google OAuth and credentials)",
    "Points balance management and tracking",
    "Request creation for dining hall points at specific UCSC locations",
    "Accept/decline requests with atomic point transfers",
    "Real-time notifications system",
    "Donation calculator for planning point donations",
    "Support for all UCSC dining halls and cafes"
  ],
  "publicApiSurface": [
    "POST /api/auth/signin - Sign in with credentials or Google",
    "GET /api/points - Get current user's points balance",
    "POST /api/points - Update points balance",
    "GET /api/requests - Fetch all requests",
    "POST /api/requests - Create a new request",
    "POST /api/requests/[id]/accept - Accept a request and transfer points",
    "POST /api/requests/[id]/decline - Decline a request",
    "DELETE /api/requests/[id] - Delete a request",
    "GET /api/notifications - Get user notifications",
    "GET /api/user - Get current user information"
  ]
